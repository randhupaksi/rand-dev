# Semua variabel di bawah opsional. Selama kosong, website menampilkan
# placeholder yang jujur (coming soon / draft) — tidak pernah link palsu.
# Salin file ini menjadi `.env` lalu isi nilai aslinya.

# Site
VITE_SITE_URL=
VITE_SITE_NAME=

# Contact (dipakai di halaman Contact & footer)
VITE_EMAIL=
VITE_WHATSAPP_NUMBER=
VITE_LOCATION=

# CV (URL file CV asli, mis. /cv/randhu-cv.pdf atau Google Drive link)
VITE_CV_URL=

# Contact form endpoint (POST JSON: { name, email, subject, message }).
# Selama kosong, form berjalan dalam mode demo dan menjelaskannya ke pengguna.
VITE_CONTACT_ENDPOINT=

# Social Links (URL profil asli; selama kosong ikon tampil sebagai placeholder)
VITE_SOCIAL_GITHUB=
VITE_SOCIAL_INSTAGRAM=
VITE_SOCIAL_LINKEDIN=
VITE_SOCIAL_DRIBBBLE=
